# ── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ⚠️  Service role key bypasses ALL Row Level Security — server-only, never expose to browser.
# If this key was ever committed to a public repo, ROTATE it immediately in the Supabase dashboard.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Razorpay ─────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_RAZORPAY_KEY_ID is the *publishable* key — safe to expose to the browser.
# Get from: https://dashboard.razorpay.com → Settings → API Keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# RAZORPAY_KEY_SECRET must remain server-only — never expose to browser.
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Webhook secret — set in Razorpay dashboard → Webhooks → Secret.
# Required for /api/webhooks/razorpay to verify incoming webhook events.
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# ── WhatsApp ──────────────────────────────────────────────────────────────────
# Admin phone number with country code, digits only. E.g. 919876543210 for India.
WHATSAPP_ADMIN_NUMBER=919876543210

# Optional: WhatsApp Cloud API token (Meta). If absent, deep-links (wa.me) are used instead.
# WHATSAPP_API_TOKEN=your_whatsapp_cloud_api_token
# WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# ── Site ──────────────────────────────────────────────────────────────────────
# Set to your production domain in production — e.g. https://www.lumierejewels.com
# Used for canonical URLs, OG images, sitemap, etc.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Admin Bootstrap ───────────────────────────────────────────────────────────
# Optional: used to create the first admin account. At least 16 characters.
# Remove or rotate after first admin is created for security.
ADMIN_BOOTSTRAP_SECRET=change_this_to_a_random_32_char_string

# ── Optional: Supabase Type Generation ───────────────────────────────────────
# Only needed for running: npm run supabase:types
# Get project ID from Supabase dashboard URL
# SUPABASE_PROJECT_ID=your_project_id_here
