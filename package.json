{
  "name": "gridaan-storefront",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready Gridaan jewelry e-commerce platform built with Next.js, Supabase, and Razorpay.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
